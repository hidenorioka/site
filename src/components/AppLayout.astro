---
import "@styles/global.css";

import Meta from "@components/Meta.astro";
import GoogleAnalytics from "@components/GoogleAnalytics.astro";

type Props = {
  title?: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <Meta title={title} />
    <GoogleAnalytics />
  </head>
  <body class="min-h-[100svh] min-w-[340px] bg-gray-100 flex flex-col">
    <main class="flex-1 flex flex-col">
      <slot />
    </main>
    <footer class="border-t-1 border-t-gray-200 mx-8 h-[50px]">
      <p class="text-[12px] text-center py-4">© 2025 hidenorioka</p>
    </footer>
  </body>
</html>
